# MCP Transport
# Options: stdio (for local), http (for VPS deployment)
MCP_TRANSPORT=stdio

# HTTP bind address (only used when MCP_TRANSPORT=http)
MCP_ADDR=0.0.0.0:3000

# SEC EDGAR Integration
# Required for: get_edgar_facts, get_edgar_submissions, get_edgar_search
# Register at: https://www.sec.gov/developer
EDGAR_EMAIL=

# FRED API Integration
# Required for: get_fred_series
# get_treasury_yields does NOT require a key
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
