        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(finance_query_http_requests_total{status=~\"5..\"}[$__rate_interval])) / sum(rate(finance_query_http_requests_total[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "v2 5xx"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(finance_query_v1_http_requests_total{status=~\"5..\"}[$__rate_interval])) / sum(rate(finance_query_v1_http_requests_total[$__rate_interval]))",
          "refId": "B",
          "legendFormat": "v1 5xx"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(finance_query_mcp_tool_calls_total{status=\"error\"}[$__rate_interval])) / sum(rate(finance_query_mcp_tool_calls_total[$__rate_interval]))",
          "refId": "C",
          "legendFormat": "MCP errors"
        }
      ],
      "title": "Error Rate by Service",
      "type": "timeseries",
      "description": "Share of failed requests per service (v2/v1: HTTP 5xx; MCP: tool calls with status=error)."
